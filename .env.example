# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true

# Skip Playwright/hCaptcha flow and call Suno API directly (recommended).
# Default: true. Set to "false" only if Suno starts rejecting direct calls
# with captcha errors — then the old browser flow kicks in as fallback.
SUNO_SKIP_CAPTCHA=true

# Shared secret for gift-song-pwa → suno-api Bearer auth on mutating endpoints.
# Generate with: openssl rand -hex 32
# Must match SUNO_API_INTERNAL_TOKEN in gift-song-pwa's Vercel env.
SUNO_API_INTERNAL_TOKEN=